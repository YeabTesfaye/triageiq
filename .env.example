# TriageIQ Environment Configuration
# Copy to .env and fill in real values before running.
# NEVER commit the .env file to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=TriageIQ
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://triageiq:triageiq@localhost:5432/triageiq
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=triageiq:

# ── JWT — CHANGE THIS IN PRODUCTION ───────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_15_MIN=20

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=15
OPENAI_MAX_RETRIES=2

# ── CORS — comma-separated, no wildcards in production ────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Observability ──────────────────────────────────────────────────────────────
ENABLE_METRICS=true
